{
  "name": "croniq",
  "version": "1.0.0",
  "description": "General-purpose scheduled data collection and monitoring platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:ui": "cd ui && npm run dev",
    "build": "tsc && cd ui && npm run build",
    "start": "node dist/server.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:export": "tsx scripts/export.ts",
    "db:seed": "tsx scripts/seed.ts",
    "sync:pull": "tsx scripts/sync.ts pull",
    "sync:push": "tsx scripts/sync.ts push",
    "sync:local-to-pi": "tsx scripts/sync.ts local-to-pi",
    "sync:pi-to-local": "tsx scripts/sync.ts pi-to-local"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.23",
    "@langchain/aws": "^1.3.1",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.2",
    "better-sqlite3": "^9.4.3",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "langchain": "^1.2.30",
    "node-cron": "^3.0.3",
    "playwright": "^1.42.1",
    "rss-parser": "^3.13.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.25",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}

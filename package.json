{
  "name": "croniq",
  "version": "1.0.0",
  "type": "module",
  "description": "General-purpose scheduled data collection and monitoring platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:ui": "cd ui && npm run dev",
    "build": "tsc && cd ui && npm run build",
    "start": "node dist/server.js",
    "test": "node ./node_modules/.bin/jest --config jest.config.cjs",
    "test:watch": "node ./node_modules/.bin/jest --config jest.config.cjs --watch",
    "db:export": "tsx scripts/export.ts",
    "db:import": "tsx scripts/import.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13",
    "bcrypt": "^5",
    "better-sqlite3": "^9.4.3",
    "better-sqlite3-session-store": "^0.1.0",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1",
    "cors": "^2.8.5",
    "csrf-csrf": "^3",
    "dotenv": "^17.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7",
    "express-session": "^1",
    "node-cron": "^3.0.3",
    "playwright": "^1.42.1",
    "rss-parser": "^3.13.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cookie-parser": "^1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^6",
    "@types/uuid": "^9.0.8",
    "aws-sdk-client-mock": "^4",
    "aws-sdk-client-mock-jest": "^4",
    "concurrently": "^8.2.2",
    "jest": "^29",
    "nock": "^13",
    "node-fetch": "^2",
    "supertest": "^6",
    "ts-jest": "^29",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  }
}
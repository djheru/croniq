# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATA_DIR=./data

# Security
SESSION_SECRET=your-secret-key-here-change-this-in-production

# CORS & WebAuthn
# Development (local):
# CORS_ORIGIN=http://localhost:5173
# RP_ID=localhost
# ORIGIN=http://localhost:5173

# Production (Pi):
CORS_ORIGIN=https://croniq.local
RP_ID=croniq.local
ORIGIN=https://croniq.local

# AWS Bedrock Configuration (optional - can use AWS credential chain instead)
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# AI Model Configuration (optional - defaults to Haiku)
# COLLECTOR_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# EDITOR_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
